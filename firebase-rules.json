{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "groups": {
      "$groupId": {
        ".read": "auth != null && (data.child('members').child(auth.uid).exists() || !data.exists())",
        ".write": "auth != null && (data.child('members').child(auth.uid).exists() || !data.exists() || (newData.child('members').child(auth.uid).exists()))",
        "members": {
          "$memberId": {
            ".write": "auth != null && (auth.uid === $memberId || data.parent().child(auth.uid).exists())"
          }
        },
        "trips": {
          ".read": "auth != null && data.parent().child('members').child(auth.uid).exists()",
          ".write": "auth != null && data.parent().child('members').child(auth.uid).exists()"
        }
      }
    }
  }
}
